{
  // Root ESLint Configuration
  //
  // This file defines the base linting rules for the project.
  // It extends recommended sets and allows for project-wide overrides.
  "root": true,
  "ignorePatterns": ["**/node_modules", "**/dist"],
  "extends": ["eslint:recommended"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {
        "@typescript-eslint/no-non-null-assertion": "off"
      }
    }
  ]
}
