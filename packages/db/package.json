{
  "name": "@aster/db",
  "version": "0.0.0",
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "build:watch": "tsc -w"
  },
  "dependencies": {
    "mongoose": "^8.3.2",
    "mongoose-field-encryption": "^7.0.1",
    "tslib": "^2.3.0",
    "yarn": "^1.22.22"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      },
      "require": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    },
    "./init": {
      "import": {
        "types": "./dist/src/init.d.ts",
        "default": "./dist/src/init.js"
      },
      "require": {
        "types": "./dist/src/init.d.ts",
        "default": "./dist/src/init.js"
      }
    }
  },
  "private": true
}
